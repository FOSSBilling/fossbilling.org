---
import { Check } from '@lucide/astro';
import Base from '../layouts/Base.astro';
import DemoCards from '../components/DemoCards.astro';
import Callout from '../components/Callout.astro';

const features = [
  'Create products & services',
  'Manage client accounts',
  'Configure payment gateways',
  'Handle support tickets',
  'Generate invoices',
  'Explore the client portal',
];
---

<Base title="Demo">
  <div class="home-content">
    <div class="content-container">
      <h1 class="headline">Try FOSSBilling</h1>
      <p class="subtitle mt-4">
        Explore the admin panel and client area without installing anything.
      </p>

      <Callout type="info" title="Demo Environment">
        The demo resets periodically. Any changes you make will be temporary.
      </Callout>
    </div>

    <div class="features-container">
      <div
        class="content-container"
        style="padding-top: 2rem; padding-bottom: 2rem;"
      >
        <DemoCards />

        <div class="demo-features-section">
          <h3>What you can try</h3>
          <div class="demo-features-grid">
            {
              features.map((feature) => (
                <div class="demo-feature-item">
                  <Check />
                  <span>{feature}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>
