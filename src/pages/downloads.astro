---
import { Book, Server, History, Container } from '@lucide/astro';
import Base from '../layouts/Base.astro';
import DownloadCards from '../components/DownloadCards.astro';
import Callout from '../components/Callout.astro';
---

<Base title="Downloads">
  <div class="home-content">
    <div class="content-container">
      <h1 class="headline">Downloads</h1>
      <p class="mt-2 subtitle">
        Download the latest version of FOSSBilling and start managing your
        hosting business.
      </p>

      <Callout type="warning" title="Before You Install">
        <ul class="list-disc ml-4 space-y-1">
          <li>
            FOSSBilling is currently <strong>pre-production software</strong>
          </li>
          <li>
            Always read the <a
              href="https://github.com/FOSSBilling/FOSSBilling/releases"
              >release notes</a
            > before updating
          </li>
          <li>
            Some technical knowledge of PHP and web hosting is recommended
          </li>
          <li>
            You must install FOSSBilling on a subdomain or the top level domain,
            not in a subfolder
          </li>
        </ul>
      </Callout>
    </div>

    <div class="features-container">
      <div
        class="content-container"
        style="padding-top: 2rem; padding-bottom: 2rem;"
      >
        <DownloadCards />

        <div class="quick-links">
          <a
            href="https://docs.fossbilling.org/getting-started/requirements/"
            class="quick-link"
          >
            <Server />
            <span>System Requirements</span>
          </a>
          <a
            href="https://docs.fossbilling.org/getting-started/installation/"
            class="quick-link"
          >
            <Book />
            <span>Installation Guide</span>
          </a>
          <a
            href="https://docs.fossbilling.org/getting-started/docker/"
            class="quick-link"
          >
            <Container />
            <span>Docker Setup</span>
          </a>
          <a
            href="https://docs.fossbilling.org/maintenance/changelog/"
            class="quick-link"
          >
            <History />
            <span>Changelog</span>
          </a>
        </div>
      </div>
    </div>

    <div class="content-container">
      <div class="need-help-section">
        <h2>Need help?</h2>
        <p>Get assistance from the community or browse the documentation.</p>
        <div class="need-help-links">
          <a href="/discord" class="need-help-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"
              ></path>
            </svg>
            <div>
              <strong>Discord</strong>
              <span>Chat with the Community</span>
            </div>
          </a>
          <a href="https://docs.fossbilling.org" class="need-help-link">
            <Book />
            <div>
              <strong>Documentation</strong>
              <span>Read the Docs</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>
