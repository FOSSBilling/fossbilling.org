---
import {
  Book,
  Server,
  History,
  Container,
  Download,
  Code,
} from '@lucide/astro';
import Base from '../layouts/Base.astro';
import DownloadCards from '../components/DownloadCards.astro';
import Callout from '../components/Callout.astro';
import BrandIcon from '../components/BrandIcon.astro';
---

<Base title="Downloads">
  <div class="home-content">
    <div class="content-container">
      <h1 class="headline">Downloads</h1>
      <p class="mt-2 subtitle">
        Download the latest version of FOSSBilling and start managing your
        hosting business.
      </p>

      <Callout type="warning" title="Before You Install">
        <ul class="list-disc ml-4 space-y-1">
          <li>
            FOSSBilling is currently <strong>pre-production software</strong>
          </li>
          <li>
            Always read the <a
              href="https://github.com/FOSSBilling/FOSSBilling/releases"
              >release notes</a
            > before updating
          </li>
          <li>
            Some technical knowledge of PHP and web hosting is recommended
          </li>
          <li>
            You must install FOSSBilling on a subdomain or the top level domain,
            not in a subfolder
          </li>
        </ul>
      </Callout>
    </div>

    <div class="features-container">
      <div
        class="content-container"
        style="padding-top: 2rem; padding-bottom: 2rem;"
      >
        <DownloadCards server:defer>
          <div slot="fallback" class="download-cards-grid">
            <div class="download-card">
              <div class="download-card-header">
                <Download class="download-card-icon" />
                <h2>Latest Release</h2>
              </div>
              <div class="download-card-empty">Loading…</div>
            </div>
            <div class="download-card">
              <div class="download-card-header">
                <Code class="download-card-icon" />
                <h2>Preview Build</h2>
              </div>
              <p class="download-card-description">
                Latest development build from the main branch.
              </p>
            </div>
          </div>
        </DownloadCards>

        <div class="quick-links">
          <a
            href="https://docs.fossbilling.org/getting-started/requirements/"
            class="quick-link"
          >
            <Server />
            <span>System Requirements</span>
          </a>
          <a
            href="https://docs.fossbilling.org/getting-started/installation/"
            class="quick-link"
          >
            <Book />
            <span>Installation Guide</span>
          </a>
          <a
            href="https://docs.fossbilling.org/getting-started/docker/"
            class="quick-link"
          >
            <Container />
            <span>Docker Setup</span>
          </a>
          <a
            href="https://docs.fossbilling.org/maintenance/changelog/"
            class="quick-link"
          >
            <History />
            <span>Changelog</span>
          </a>
        </div>
      </div>
    </div>

    <div class="content-container">
      <div class="need-help-section">
        <h2>Need help?</h2>
        <p>Get assistance from the community or browse the documentation.</p>
        <div class="need-help-links">
          <a href="/discord" class="need-help-link">
            <BrandIcon name="discord" class="h-6 w-6" />
            <div>
              <strong>Discord</strong>
              <span>Chat with the Community</span>
            </div>
          </a>
          <a href="https://docs.fossbilling.org" class="need-help-link">
            <Book />
            <div>
              <strong>Documentation</strong>
              <span>Read the Docs</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>
