---
interface Props {
  text: string;
  href?: string;
  class?: string;
}

const { text, href, class: className = '' } = Astro.props;

const baseClasses =
  'px-5 py-3 text-base font-medium text-center inline-flex items-center text-white! bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800 mr-4';

const classes = `${baseClasses} ${className}`;
---

{
  href ? (
    <a href={href} class={classes}>
      {text}
    </a>
  ) : (
    <button type="button" class={classes}>
      {text}
    </button>
  )
}
