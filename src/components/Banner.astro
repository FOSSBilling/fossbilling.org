---
import { ArrowRight } from '@lucide/astro';
import { getLatestStableReleaseCached } from '@/lib/releases';

const { release } = await getLatestStableReleaseCached();
const version = release?.version ?? null;
const storageKey = version ? `${version}-release` : null;
---

{
  version && storageKey && (
    <div
      class="z-40 bg-black text-white text-center text-sm py-2 px-4"
      data-banner
      data-banner-key={storageKey}
    >
      <span class="font-semibold">FOSSBilling {version} is now available!</span>{' '}
      We strongly recommend upgrading from older versions.{' '}
      <a
        href="https://github.com/FOSSBilling/FOSSBilling/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="underline hover:text-gray-300 inline-flex items-center gap-1"
      >
        Read more <ArrowRight class="h-3 w-3" />
      </a>
      <button
        type="button"
        data-banner-dismiss
        class="ml-4 opacity-70 hover:opacity-100"
        aria-label="Dismiss"
      >
        &times;
      </button>
    </div>
  )
}
