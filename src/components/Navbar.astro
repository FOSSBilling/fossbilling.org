---
import ThemeToggle from './ThemeToggle.astro';
import BrandIcon from './BrandIcon.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const navItems = [
  {
    title: 'Documentation',
    href: 'https://docs.fossbilling.org/',
    external: true,
  },
  { title: 'Downloads', href: '/downloads' },
  { title: 'Demo', href: '/demo' },
  {
    title: 'Translate',
    href: 'https://translate.fossbilling.org/',
    external: true,
  },
  {
    title: 'Donate',
    items: [
      {
        title: 'Open Collective',
        href: 'https://opencollective.com/FOSSBilling',
      },
      {
        title: 'GitHub Sponsors',
        href: 'https://github.com/sponsors/FOSSBilling',
      },
    ],
  },
];
---

<header class:list={['z-30 w-full print:hidden', className]}>
  <div
    class="absolute inset-0 -z-1 border-b border-gray-200 dark:border-gray-800 backdrop-blur-md bg-white/70 dark:bg-[#111111]/70"
  >
  </div>
  <nav
    class="mx-auto flex max-w-[90rem] items-center justify-between gap-4 pl-[max(env(safe-area-inset-left),1.5rem)] pr-[max(env(safe-area-inset-right),1.5rem)]"
    style="height: 64px;"
  >
    <a href="/" class="flex items-center" aria-label="Home page">
      <span class="logo block"></span>
    </a>

    <div class="flex items-center gap-2 md:gap-4">
      <div class="hidden md:flex items-center gap-4" data-desktop-nav>
        {
          navItems.map((item) =>
            item.items ? (
              <div class="relative" data-dropdown>
                <button
                  type="button"
                  data-dropdown-toggle
                  aria-expanded="false"
                  aria-haspopup="menu"
                  class="text-sm text-gray-600 hover:text-black dark:text-gray-400 dark:hover:text-gray-200 flex items-center gap-1 cursor-pointer whitespace-nowrap transition-colors"
                >
                  {item.title}
                  <svg
                    width="10"
                    height="6"
                    viewBox="0 0 10 6"
                    class="transition-transform"
                    data-dropdown-chevron
                  >
                    <path
                      d="M1 1l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.5"
                      fill="none"
                    />
                  </svg>
                </button>
                <div
                  role="menu"
                  class="absolute right-0 mt-2 w-48 rounded-md border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#1a1a1a] shadow-lg py-1 z-50 hidden"
                  data-dropdown-menu
                >
                  {item.items.map((sub) => (
                    <a
                      href={sub.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      role="menuitem"
                      class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-800"
                    >
                      {sub.title}
                    </a>
                  ))}
                </div>
              </div>
            ) : item.external ? (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-600 hover:text-black dark:text-gray-400 dark:hover:text-gray-200 whitespace-nowrap transition-colors"
              >
                {item.title}
              </a>
            ) : (
              <a
                href={item.href}
                class="text-sm text-gray-600 hover:text-black dark:text-gray-400 dark:hover:text-gray-200 whitespace-nowrap transition-colors"
              >
                {item.title}
              </a>
            ),
          )
        }
      </div>

      <slot name="extras" />

      <a
        href="/discord"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Discord"
        class="p-2 md:p-0 text-gray-600 hover:text-black dark:text-gray-400 dark:hover:text-gray-200 transition-colors"
      >
        <BrandIcon name="discord" class="h-5 w-5" />
      </a>

      <ThemeToggle />

      <button
        type="button"
        data-mobile-toggle
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-navigation-menu"
        class="p-2 md:hidden text-gray-600 dark:text-gray-400"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          data-mobile-icon-open
        >
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          data-mobile-icon-close
          class="hidden"
        >
          <path d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-navigation-menu"
    class="md:hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#111111] hidden"
    data-mobile-menu
  >
    <div class="flex flex-col gap-2 p-4" role="menu">
      {
        navItems.map((item) =>
          item.items ? (
            <div role="none">
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
                {item.title}
              </span>
              <div class="ml-4 flex flex-col gap-1 mt-1">
                {item.items.map((sub) => (
                  <a
                    href={sub.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    role="menuitem"
                    class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 py-1"
                  >
                    {sub.title}
                  </a>
                ))}
              </div>
            </div>
          ) : item.external ? (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              role="menuitem"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 py-1"
            >
              {item.title}
            </a>
          ) : (
            <a
              href={item.href}
              role="menuitem"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 py-1"
            >
              {item.title}
            </a>
          ),
        )
      }
    </div>
  </div>
</header>
