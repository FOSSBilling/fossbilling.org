---
import BrandIcon from './BrandIcon.astro';

const socials = [
  {
    href: '/discord',
    label: 'Discord',
    icon: 'discord' as const,
  },
  {
    href: 'https://fosstodon.org/@fossbilling',
    label: 'Mastodon',
    icon: 'mastodon' as const,
  },
  {
    href: 'https://twitter.com/FOSSBilling',
    label: 'X (Twitter)',
    icon: 'x' as const,
  },
  {
    href: 'https://status.fossbilling.org/',
    label: 'Status page',
    icon: 'status' as const,
  },
];
---

<div class="mb-6">
  {
    socials.map((social, i) => (
      <a
        href={social.href}
        class:list={[
          'hover:text-gray-500 dark:hover:text-gray-300',
          i < socials.length - 1 ? 'mr-4' : '',
        ]}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={social.label}
      >
        <BrandIcon name={social.icon} class="h-5 w-5 inline" />
      </a>
    ))
  }
</div>
