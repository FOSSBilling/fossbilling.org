---
import {
  Receipt,
  Server,
  Globe,
  Headset,
  Puzzle,
  ShieldCheck,
  Code,
  Heart,
  ArrowRight,
  Lock,
  Users,
  Languages,
} from '@lucide/astro';
import LogoSlider from './LogoSlider.astro';
import Button from './Button.astro';
import Reveal from './Reveal.astro';
import BrandIcon from './BrandIcon.astro';

interface FeatureCardData {
  icon: typeof Server;
  title: string;
  description: string;
  href?: string;
}

const features: FeatureCardData[] = [
  {
    icon: Receipt,
    title: 'Automated Billing',
    description:
      'Generate invoices automatically, send payment reminders, and support multiple currencies with automatic exchange rate syncing.',
    href: 'https://docs.fossbilling.org/support/features/#currency-support',
  },
  {
    icon: Server,
    title: 'Hosting Provisioning',
    description:
      'Automatically provision hosting accounts on cPanel, Plesk, DirectAdmin, HestiaCP, and more.',
    href: 'https://docs.fossbilling.org/admin-guide/product-types/hosting/',
  },
  {
    icon: Globe,
    title: 'Domain Management',
    description:
      'Register, transfer, and manage domains with support for multiple registrars and experimental support for EPP-based registries.',
    href: 'https://docs.fossbilling.org/admin-guide/product-types/domains/',
  },
  {
    icon: Headset,
    title: 'Support Ticketing',
    description:
      'Built-in helpdesk with email notifications, automatic ticket closure, and support for both clients and guests.',
    href: 'https://docs.fossbilling.org/support/features/#tickets--helpdesk',
  },
  {
    icon: Puzzle,
    title: 'Extensible Architecture',
    description:
      'Install themes, modules, payment gateways, server managers, and domain registrars from the extension directory.',
    href: 'https://docs.fossbilling.org/extensions-and-development/extensions/',
  },
  {
    icon: ShieldCheck,
    title: 'Security First',
    description:
      'IP blocking, reCAPTCHA, spam protection, CSRF prevention, and activity logging to keep your business safe.',
    href: 'https://docs.fossbilling.org/security/best-practices/',
  },
];

const pillars = [
  {
    icon: Code,
    title: '100% Open Source',
    description:
      'Licensed under AGPL 3.0. Audit the code, contribute features, or fork it for your needs. No encoded files, no secrets.',
  },
  {
    icon: Lock,
    title: 'Self-Hosted',
    description:
      'Your data stays on your server. Full control over your infrastructure, backups, and security policies.',
  },
  {
    icon: Users,
    title: 'Community Driven',
    description:
      'Active development with contributions from developers worldwide. Join our Discord server to get involved.',
  },
];

const community = [
  {
    label: 'GitHub',
    href: 'https://github.com/FOSSBilling/FOSSBilling',
    description: 'Star the repo, report issues, or contribute code',
    brand: 'github',
  },
  {
    label: 'Discord',
    href: '/discord',
    description: 'Chat with the community and get real-time help',
    brand: 'discord',
  },
  {
    icon: Languages,
    label: 'Translate',
    href: 'https://translate.fossbilling.org',
    description: 'Help bring FOSSBilling to more languages',
  },
  {
    icon: Heart,
    label: 'Donate',
    href: 'https://opencollective.com/fossbilling',
    description: 'Help fund development and infrastructure',
  },
];
---

<div class="home-content">
  {/* Hero Section */}
  <div class="content-container hero-section">
    <h1 class="headline reveal">
      Free and open source<br class="sm:block hidden" /> hosting automation.
    </h1>
    <p class="subtitle mt-6 reveal">
      Run your hosting business with FOSSBilling, the free<br
         class="sm:block hidden"
       />
      and open source solution for billing and client management.
    </p>
    <div class="hero-buttons reveal">
      <Button
        text="Get Started"
        href="https://docs.fossbilling.org/getting-started/"
      />
      <Button text="Download FOSSBilling" href="/downloads" />
    </div>
    <div class="reveal">
      <a href="https://docs.fossbilling.org/getting-started/installation/">
        <span
          class="text-blue-700 hover:text-blue-800 dark:text-blue-500 dark:hover:text-blue-400 hover:underline hover:underline-offset-2"
        >
          Installation Instructions
        </span>
      </a>
    </div>
  </div>

  {/* Integrations Section */}
  <div class="features-container">
    <LogoSlider />

    {/* Feature Cards Grid */}
    <div class="content-container">
      <Reveal class="section-header">
        <h2>Everything you need to run your hosting business</h2>
        <p>
          FOSSBilling provides all the tools you need to manage clients,
          automate billing, and provision services.
        </p>
      </Reveal>

      <div class="feature-cards-grid">
        {
          features.map((feature) => {
            const card = (
              <div class="feature-card group reveal">
                <div class="feature-card-icon">
                  <feature.icon />
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
                {feature.href && (
                  <span class="feature-card-link">
                    Learn more <ArrowRight class="arrow" />
                  </span>
                )}
              </div>
            );
            return feature.href ? <a href={feature.href}>{card}</a> : card;
          })
        }
      </div>
    </div>

    {/* Why FOSSBilling Section */}
    <div class="content-container why-section">
      <Reveal class="section-header">
        <h2>Why choose FOSSBilling?</h2>
        <p>
          Built by the community, for the community. No hidden costs, no vendor
          lock-in.
        </p>
      </Reveal>

      <div class="pillars-grid">
        {
          pillars.map((pillar) => (
            <Reveal class="pillar-card">
              <div class="pillar-icon">
                <pillar.icon />
              </div>
              <h3>{pillar.title}</h3>
              <p>{pillar.description}</p>
            </Reveal>
          ))
        }
      </div>
    </div>

    {/* CTA Section */}
    <div class="content-container cta-section">
      <Reveal class="cta-content">
        <h2>Ready to get started?</h2>
        <p>
          Download FOSSBilling today and start managing your hosting business.
        </p>
        <div class="cta-buttons">
          <Button text="Download FOSSBilling" href="/downloads" />
          <a href="/demo">
            <span class="cta-secondary">
              Try the demo <ArrowRight class="ml-2" />
            </span>
          </a>
        </div>
      </Reveal>
    </div>

    {/* Community Section */}
    <div class="content-container community-section">
      <Reveal class="section-header">
        <h2>Join the community</h2>
        <p>Get help, share ideas, and contribute to FOSSBilling.</p>
      </Reveal>

      <div class="community-grid">
        {
          community.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="community-card reveal"
            >
              {item.brand === 'github' && (
                <BrandIcon name="github" class="h-8 w-8" />
              )}
              {item.brand === 'discord' && (
                <BrandIcon name="discord" class="h-8 w-8" />
              )}
              {item.icon && <item.icon width="32" height="32" />}
              <h3>{item.label}</h3>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
